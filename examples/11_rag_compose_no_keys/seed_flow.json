{
  "schema_version": "1",
  "flow": {
    "name": "Seed mini-library",
    "slug": "seed-mini-library",
    "description": "Ingestion as a flow: literal corpus -> splitter -> pgvector writer."
  },
  "nodes": [
    {
      "id": "start",
      "component_id": "lga.io.start",
      "component_version": "1.0.0",
      "config": {},
      "position": { "x": 0, "y": 140 }
    },
    {
      "id": "corpus",
      "component_id": "lga.io.text_input",
      "component_version": "1.0.0",
      "config": {
        "value": "The Left Hand of Darkness was written by Ursula K. Le Guin and published in 1969. It explores gender and society on the planet Gethen.\n\nDune was written by Frank Herbert in 1965. It follows Paul Atreides on the desert planet Arrakis, source of the spice melange.\n\nNeuromancer was written by William Gibson in 1984 and coined the term cyberspace. It is the founding novel of the cyberpunk genre."
      },
      "position": { "x": 260, "y": 60 }
    },
    {
      "id": "splitter",
      "component_id": "lga.rag.text_splitter",
      "component_version": "1.0.0",
      "config": { "chunk_size": 200, "chunk_overlap": 0 },
      "position": { "x": 520, "y": 140 }
    },
    {
      "id": "writer",
      "component_id": "lga.rag.pgvector_writer",
      "component_version": "1.0.0",
      "config": {
        "collection": "mini-library",
        "embeddings": { "provider": "fake", "model": "" }
      },
      "position": { "x": 780, "y": 140 }
    },
    {
      "id": "end",
      "component_id": "lga.io.end",
      "component_version": "1.0.0",
      "config": {},
      "position": { "x": 1040, "y": 140 }
    }
  ],
  "edges": [
    {
      "id": "e1",
      "kind": "data",
      "source": { "node": "start", "output": "message" },
      "target": { "node": "corpus", "input": "input" }
    },
    {
      "id": "e2",
      "kind": "data",
      "source": { "node": "corpus", "output": "text" },
      "target": { "node": "splitter", "input": "text" }
    },
    {
      "id": "e3",
      "kind": "data",
      "source": { "node": "splitter", "output": "documents" },
      "target": { "node": "writer", "input": "documents" }
    },
    {
      "id": "e4",
      "kind": "data",
      "source": { "node": "writer", "output": "json" },
      "target": { "node": "end", "input": "json" }
    }
  ]
}
