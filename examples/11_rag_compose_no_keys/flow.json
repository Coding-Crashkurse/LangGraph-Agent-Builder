{
  "schema_version": "1",
  "flow": {
    "name": "RAG without keys",
    "slug": "rag-no-keys",
    "description": "Real pgvector retrieval, fake embeddings, echo model - zero API keys.",
    "a2a": {
      "enabled": true,
      "description": "Answers questions over the seeded mini-library using real pgvector retrieval; the echo model returns the rendered prompt so you can see exactly what was retrieved.",
      "examples": ["Who wrote The Left Hand of Darkness?"]
    }
  },
  "nodes": [
    {
      "id": "start",
      "component_id": "lga.io.start",
      "component_version": "1.0.0",
      "config": {},
      "position": { "x": 0, "y": 160 }
    },
    {
      "id": "retriever",
      "component_id": "lga.rag.pgvector_retriever",
      "component_version": "1.0.0",
      "config": {
        "collection": "mini-library",
        "k": 2,
        "embeddings": { "provider": "fake", "model": "" }
      },
      "position": { "x": 300, "y": 60 }
    },
    {
      "id": "answer",
      "component_id": "lga.llm.llm_call",
      "component_version": "1.0.0",
      "config": {
        "prompt": "Context:\n{context}\n\nQuestion: {question}",
        "model": { "provider": "echo", "model": "" },
        "stream_tokens": false
      },
      "position": { "x": 620, "y": 160 }
    },
    {
      "id": "end",
      "component_id": "lga.io.end",
      "component_version": "1.0.0",
      "config": {},
      "position": { "x": 940, "y": 160 }
    }
  ],
  "edges": [
    {
      "id": "e1",
      "kind": "data",
      "source": { "node": "start", "output": "message" },
      "target": { "node": "retriever", "input": "query" }
    },
    {
      "id": "e2",
      "kind": "data",
      "source": { "node": "retriever", "output": "documents" },
      "target": { "node": "answer", "input": "context" }
    },
    {
      "id": "e3",
      "kind": "data",
      "source": { "node": "start", "output": "message" },
      "target": { "node": "answer", "input": "question" }
    },
    {
      "id": "e4",
      "kind": "data",
      "source": { "node": "answer", "output": "message" },
      "target": { "node": "end", "input": "message" }
    }
  ]
}
