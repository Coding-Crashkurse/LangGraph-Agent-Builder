{
  "schema_version": "1",
  "flow": {
    "name": "router branches",
    "slug": "router-branches",
    "description": "LLM router (3 labels) with rule-router fallback.",
    "a2a": { "enabled": true, "description": "Routes support messages into billing, bug or other lanes.", "examples": ["I found a bug in the export"] }
  },
  "nodes": [
    { "id": "start", "component_id": "lab.io.start", "component_version": "1.0.0", "config": {}, "position": { "x": 0, "y": 160 } },
    { "id": "route", "component_id": "lab.flow.llm_router", "component_version": "1.0.0",
      "config": { "labels": ["billing", "bug", "other"] }, "position": { "x": 240, "y": 160 } },
    { "id": "billing", "component_id": "lab.testing.fake_llm", "component_version": "1.0.0",
      "config": { "replies": ["Routed to BILLING: our finance team will follow up."] }, "position": { "x": 520, "y": 40 } },
    { "id": "bug", "component_id": "lab.testing.fake_llm", "component_version": "1.0.0",
      "config": { "replies": ["Routed to BUG: filed in the tracker."] }, "position": { "x": 520, "y": 160 } },
    { "id": "fallback", "component_id": "lab.flow.rule_router", "component_version": "1.0.0",
      "config": { "rules": [ { "label": "urgent", "when": "\"asap\" in message" } ], "default_label": "normal" },
      "position": { "x": 520, "y": 300 } },
    { "id": "urgent", "component_id": "lab.testing.fake_llm", "component_version": "1.0.0",
      "config": { "replies": ["Routed to OTHER/URGENT: escalating now."] }, "position": { "x": 780, "y": 260 } },
    { "id": "normal", "component_id": "lab.testing.fake_llm", "component_version": "1.0.0",
      "config": { "replies": ["Routed to OTHER/NORMAL: queued."] }, "position": { "x": 780, "y": 380 } },
    { "id": "end", "component_id": "lab.io.end", "component_version": "1.0.0", "config": {}, "position": { "x": 1040, "y": 160 } }
  ],
  "edges": [
    { "id": "e1", "kind": "data", "source": { "node": "start", "output": "message" }, "target": { "node": "route", "input": "input" } },
    { "id": "r1", "kind": "router", "source": { "node": "route", "output": "billing" }, "target": { "node": "billing", "input": "input" } },
    { "id": "r2", "kind": "router", "source": { "node": "route", "output": "bug" }, "target": { "node": "bug", "input": "input" } },
    { "id": "r3", "kind": "router", "source": { "node": "route", "output": "other" }, "target": { "node": "fallback", "input": "input" } },
    { "id": "r4", "kind": "router", "source": { "node": "fallback", "output": "urgent" }, "target": { "node": "urgent", "input": "input" } },
    { "id": "r5", "kind": "router", "source": { "node": "fallback", "output": "normal" }, "target": { "node": "normal", "input": "input" } },
    { "id": "e2", "kind": "data", "source": { "node": "billing", "output": "message" }, "target": { "node": "end", "input": "message" } },
    { "id": "e3", "kind": "data", "source": { "node": "bug", "output": "message" }, "target": { "node": "end", "input": "message" } },
    { "id": "e4", "kind": "data", "source": { "node": "urgent", "output": "message" }, "target": { "node": "end", "input": "message" } },
    { "id": "e5", "kind": "data", "source": { "node": "normal", "output": "message" }, "target": { "node": "end", "input": "message" } }
  ]
}
