{
  "schema_version": "1",
  "flow": {
    "name": "agent with tools",
    "slug": "agent-tools",
    "description": "LLM agent with calculator and http_request tools attached.",
    "a2a": { "enabled": true, "description": "Agent that can calculate and fetch URLs.", "examples": ["what is (2+3)*4?"] }
  },
  "nodes": [
    { "id": "start", "component_id": "lab.io.start", "component_version": "1.0.0", "config": {}, "position": { "x": 0, "y": 120 } },
    { "id": "agent", "component_id": "lab.llm.llm_agent", "component_version": "1.0.0",
      "config": { "model": { "provider": "fake", "model": "I would use my tools for that." }, "system_prompt": "You are a helpful assistant. Use tools when math or web content is needed." },
      "position": { "x": 320, "y": 120 } },
    { "id": "calc", "component_id": "lab.tools.calculator", "component_version": "1.0.0", "config": { "expression": "0" }, "position": { "x": 320, "y": 320 } },
    { "id": "web", "component_id": "lab.tools.http_request", "component_version": "1.0.0", "config": { "url": "https://example.com" }, "position": { "x": 520, "y": 320 } },
    { "id": "end", "component_id": "lab.io.end", "component_version": "1.0.0", "config": {}, "position": { "x": 640, "y": 120 } }
  ],
  "edges": [
    { "id": "e1", "kind": "data", "source": { "node": "start", "output": "message" }, "target": { "node": "agent", "input": "input" } },
    { "id": "t1", "kind": "tool", "source": { "node": "calc", "output": "toolset" }, "target": { "node": "agent", "input": "tools" } },
    { "id": "t2", "kind": "tool", "source": { "node": "web", "output": "toolset" }, "target": { "node": "agent", "input": "tools" } },
    { "id": "e2", "kind": "data", "source": { "node": "agent", "output": "message" }, "target": { "node": "end", "input": "message" } }
  ]
}
