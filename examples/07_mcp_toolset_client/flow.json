{
  "schema_version": "1",
  "flow": {
    "name": "mcp toolset client",
    "slug": "mcp-toolset-client",
    "description": "Agent using tools from an external MCP server.",
    "a2a": { "enabled": true, "description": "Support agent with order tools from an external MCP server.", "examples": ["where is order 1001?"] }
  },
  "nodes": [
    { "id": "start", "component_id": "lab.io.start", "component_version": "1.0.0", "config": {}, "position": { "x": 0, "y": 120 } },
    { "id": "agent", "component_id": "lab.llm.llm_agent", "component_version": "1.0.0",
      "config": { "model": { "provider": "fake", "model": "Checking with my order tools." }, "system_prompt": "Use the order tools to answer." },
      "position": { "x": 320, "y": 120 } },
    { "id": "tools", "component_id": "lab.tools.mcp_toolset", "component_version": "1.0.0",
      "config": { "transport": "streamable_http", "url": "http://127.0.0.1:9007/mcp" },
      "position": { "x": 320, "y": 320 } },
    { "id": "end", "component_id": "lab.io.end", "component_version": "1.0.0", "config": {}, "position": { "x": 640, "y": 120 } }
  ],
  "edges": [
    { "id": "e1", "kind": "data", "source": { "node": "start", "output": "message" }, "target": { "node": "agent", "input": "input" } },
    { "id": "t1", "kind": "tool", "source": { "node": "tools", "output": "toolset" }, "target": { "node": "agent", "input": "tools" } },
    { "id": "e2", "kind": "data", "source": { "node": "agent", "output": "message" }, "target": { "node": "end", "input": "message" } }
  ]
}
