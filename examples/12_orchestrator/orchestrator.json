{
  "schema_version": "1",
  "flow": {
    "name": "Orchestrator",
    "slug": "orchestrator",
    "description": "Routes requests to specialist A2A agents (greeter / shouter).",
    "a2a": {
      "enabled": true,
      "description": "Front desk: understands the request and delegates to the right specialist agent over A2A.",
      "examples": ["greet me", "shout: build faster"]
    }
  },
  "nodes": [
    { "id": "start", "component_id": "lab.io.start", "component_version": "1.0.0",
      "config": {}, "position": { "x": 0, "y": 180 } },
    { "id": "triage", "component_id": "lab.flow.llm_router", "component_version": "1.0.0",
      "config": { "labels": ["greet", "shout"] },
      "position": { "x": 280, "y": 180 } },
    { "id": "greeter", "component_id": "lab.tools.a2a_remote_agent",
      "component_version": "1.0.0",
      "config": { "agent_url": "http://127.0.0.1:8000/a2a/greeter-agent", "mode": "node" },
      "position": { "x": 580, "y": 60 } },
    { "id": "shouter", "component_id": "lab.tools.a2a_remote_agent",
      "component_version": "1.0.0",
      "config": { "agent_url": "http://127.0.0.1:8000/a2a/shouter-agent", "mode": "node" },
      "position": { "x": 580, "y": 300 } },
    { "id": "end", "component_id": "lab.io.end", "component_version": "1.0.0",
      "config": {}, "position": { "x": 880, "y": 180 } }
  ],
  "edges": [
    { "id": "e1", "kind": "data", "source": { "node": "start", "output": "message" },
      "target": { "node": "triage", "input": "input" } },
    { "id": "r1", "kind": "router", "source": { "node": "triage", "output": "greet" },
      "target": { "node": "greeter", "input": "" } },
    { "id": "r2", "kind": "router", "source": { "node": "triage", "output": "shout" },
      "target": { "node": "shouter", "input": "" } },
    { "id": "e2", "kind": "data", "source": { "node": "greeter", "output": "message" },
      "target": { "node": "end", "input": "message" } },
    { "id": "e3", "kind": "data", "source": { "node": "shouter", "output": "message" },
      "target": { "node": "end", "input": "message" } }
  ]
}
