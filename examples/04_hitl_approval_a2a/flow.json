{
  "schema_version": "1",
  "flow": {
    "name": "hitl approval",
    "slug": "hitl-approval",
    "description": "Draft, human approval, release — over A2A.",
    "a2a": { "enabled": true, "description": "Drafts an answer and pauses for human approval before releasing it.", "examples": ["draft a reply to the refund request"] }
  },
  "nodes": [
    { "id": "start", "component_id": "lab.io.start", "component_version": "1.0.0", "config": {}, "position": { "x": 0, "y": 120 } },
    { "id": "draft", "component_id": "lab.testing.fake_llm", "component_version": "1.0.0",
      "config": { "replies": ["Draft: we will refund the order.", "Draft v2: refund plus a voucher."] },
      "position": { "x": 260, "y": 120 } },
    { "id": "review", "component_id": "lab.flow.human_approval", "component_version": "1.0.0",
      "config": { "prompt": "Release this answer?" }, "position": { "x": 520, "y": 120 } },
    { "id": "end", "component_id": "lab.io.end", "component_version": "1.0.0", "config": {}, "position": { "x": 780, "y": 120 } }
  ],
  "edges": [
    { "id": "e1", "kind": "data", "source": { "node": "start", "output": "message" }, "target": { "node": "draft", "input": "input" } },
    { "id": "e2", "kind": "data", "source": { "node": "draft", "output": "message" }, "target": { "node": "review", "input": "input" } },
    { "id": "e3", "kind": "router", "source": { "node": "review", "output": "approve" }, "target": { "node": "end", "input": "result" } },
    { "id": "e4", "kind": "router", "source": { "node": "review", "output": "reject" }, "target": { "node": "draft", "input": "input" } }
  ]
}
