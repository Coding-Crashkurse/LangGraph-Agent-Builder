# LangGraph Agent Builder — example env. All settings use the BUILDER_ prefix
# (services/settings.py is the single loader; no other module reads os.environ).
# Copy to .env and uncomment what you need; values are the defaults unless a
# line says otherwise (URLs are illustrative examples — their default is empty).

# dev | prod | test — dev additionally allows the Vite origin (:5173) in CORS.
#BUILDER_ENV=dev

# Bind address of the builder itself. NOTE: `lab serve` reads these settings;
# in the Docker image they default to 0.0.0.0:8010.
#BUILDER_HOST=127.0.0.1
#BUILDER_PORT=8000

# Builder state directory (SQLite drafts DB lives here when BUILDER_DATABASE_URL
# is unset).
#BUILDER_HOME=~/.langgraph-agent-builder

# Async SQLAlchemy URL for the drafts store. Empty → sqlite+aiosqlite under
# BUILDER_HOME. Example for the compose Postgres (port 55432 on this machine):
#BUILDER_DATABASE_URL=postgresql+asyncpg://lab:lab@localhost:55432/lab

# Public base URL of the builder (CORS + links). Empty → http://HOST:PORT.
#BUILDER_HOST_URL=

# Dev override for the bundled frontend: path to a built dist/ directory.
# Empty → the _static bundle inside the installed package.
#BUILDER_FRONTEND_PATH=

# uvicorn log level.
#BUILDER_LOG_LEVEL=info

# agentplane runtime API — always a gateway URL, never an internal address.
#BUILDER_RUNTIME_URL=http://localhost:8080/runtime

# Static bearer for dev setups without OIDC (BUILDER_AUTH_MODE=none). With
# auth_mode=oidc the caller's token is forwarded instead. Keep real tokens in
# .env only — never commit them.
#BUILDER_RUNTIME_TOKEN=

# none | oidc — oidc validates JWTs against the shared Keycloak realm and
# requires BUILDER_OIDC_ISSUER.
#BUILDER_AUTH_MODE=none
#BUILDER_OIDC_ISSUER=http://localhost:8081/realms/agentplane
#BUILDER_OIDC_AUDIENCE=
# Public client id the frontend uses for Authorization Code + PKCE.
#BUILDER_OIDC_CLIENT_ID=

# Links into the platform UI (agentplane-ui): "Manage in Resources" and the
# registry link shown after publish.
#BUILDER_RESOURCES_UI_URL=
#BUILDER_REGISTRY_UI_URL=
