          "advanced": false,
          "toggleable": false
        },
        "url": {
          "widget": "text",
          "label": "Server URL",
          "help": "Used when no resource is set.",
          "placeholder": "",
          "resource_kind": null,
          "advanced": true,
          "toggleable": false
        },
        "tool": {
          "widget": "text",
          "label": "Tool Name",
          "help": "",
          "placeholder": "",
          "resource_kind": null,
          "advanced": false,
          "toggleable": false
        },
        "args": {
          "widget": "dict",
          "label": "Arguments",
          "help": "input port name → tool argument name",
          "placeholder": "",
          "resource_kind": null,
          "advanced": false,
          "toggleable": false
        }
      },
      "default_config": {}
    },
    {
      "type": "router",
      "version": 1,
      "label": "Router",
      "icon": "git-branch",
      "category": "flow",
      "description": "If/else branching: routes the input value to the first matching branch.",
      "config_schema": {
        "$defs": {
          "JsonValue": {},
          "RouterRule": {
            "additionalProperties": false,
            "description": "One branch condition, evaluated in order; first match wins.\n\n``path`` (dot notation, JSON inputs only) selects the value under test —\nempty means the whole input. ``equals``/``not_equals`` compare it to\n``value``; ``contains`` is substring/membership/key test; ``gt``/``gte``/\n``lt``/``lte`` compare numerically. A missing path resolves to null: it\nmatches ``empty`` and never matches a comparison.",
            "properties": {
              "when": {
                "enum": [
                  "not_empty",
                  "empty",
                  "equals",
                  "not_equals",
                  "contains",
                  "gt",
                  "gte",
                  "lt",
                  "lte"
                ],
                "title": "When",
                "type": "string"
              },
              "branch": {
                "pattern": "^[a-z][a-z0-9_]*$",
                "title": "Branch",
                "type": "string"
              },
              "path": {
                "default": "",
                "description": "Dot path into a JSON input selecting the value under test; empty = input.",
                "title": "Path",
                "type": "string"
              },
              "value": {
                "$ref": "#/$defs/JsonValue",
                "default": null,
                "description": "Comparison operand; required for every condition except empty/not_empty."
              }
            },
            "required": [
              "when",
              "branch"
            ],
            "title": "RouterRule",
            "type": "object"
          }
        },
        "additionalProperties": false,
        "description": "Conditional branching (v1.1): routes the input value to one branch.\n\nEvery rule branch plus the default branch becomes a typed output port\nthat passes the input value through; only the chosen branch's downstream\nnodes execute.",
        "properties": {
          "input_type": {
            "default": "text",
            "enum": [
              "text",
              "json",
              "documents"
            ],
            "title": "Input Type",
            "type": "string"
          },
          "rules": {
            "items": {
              "$ref": "#/$defs/RouterRule"
            },
            "minItems": 1,
            "title": "Rules",
            "type": "array"
          },
          "default_branch": {
            "default": "otherwise",
            "pattern": "^[a-z][a-z0-9_]*$",
            "title": "Default Branch",
            "type": "string"
          }
        },
        "required": [
          "rules"
        ],
        "title": "RouterNodeConfig",
        "type": "object"
      },
      "inputs": [],
      "outputs": [],
      "dynamic_inputs": "router_input",
      "dynamic_outputs": "router_branches",
      "ui": {
        "input_type": {
          "widget": "text",
          "label": "Input Type",
          "help": "Port type flowing through the branches (text | json | documents).",
          "placeholder": "",
          "resource_kind": null,
          "advanced": false,
          "toggleable": false
        },
        "rules": {
          "widget": "json",
          "label": "Rules",
          "help": "Ordered conditions, first match wins: [{\"when\": \"not_empty\", \"branch\": \"found\"}]",
          "placeholder": "",
          "resource_kind": null,
          "advanced": false,
          "toggleable": false
        },
        "default_branch": {
          "widget": "text",
          "label": "Default Branch",
          "help": "Taken when no rule matches.",
          "placeholder": "",
          "resource_kind": null,
          "advanced": false,
          "toggleable": false
        }
      },
      "default_config": {
        "input_type": "text",
        "rules": [
          {
            "when": "not_empty",
            "branch": "found"
          }
        ],
        "default_branch": "otherwise"
      }
    },
    {
      "type": "template",
      "version": 1,
      "label": "Template",
      "icon": "type",
      "category": "flow",
      "description": "Static or interpolated text; {vars} become input ports (fallback messages).",
      "config_schema": {
        "additionalProperties": false,
        "description": "Static/interpolated text (v1.1): `{vars}` become input ports.\n\nThe `trigger` input port exists on every template so a router branch can\nactivate it even when the text needs no variables (fallback messages).",
        "properties": {
          "text": {
            "title": "Text",
            "type": "string"
          }
        },
        "required": [
          "text"
        ],
        "title": "TemplateNodeConfig",
        "type": "object"
      },
      "inputs": [],
      "outputs": [
        {
          "name": "text",
          "type": "text",
          "label": "Text"
        }
      ],
      "dynamic_inputs": "template_vars",
      "dynamic_outputs": null,
      "ui": {
        "text": {
          "widget": "prompt",
          "label": "Text",
          "help": "Rendered as-is; {vars} become input ports. The trigger port activates the node from a router branch.",
          "placeholder": "",
          "resource_kind": null,
          "advanced": false,
          "toggleable": false
        }
      },
      "default_config": {
        "text": ""
      }
    },
    {
      "type": "retrieval",
      "version": 1,
      "label": "Knowledge Base",
      "icon": "database",
      "category": "rag",
      "description": "Similarity search on an existing vector DB (read-only).",
      "config_schema": {
        "$defs": {
          "JsonValue": {}
        },
        "additionalProperties": false,
        "properties": {
          "resource": {
            "pattern": "^[a-z0-9][a-z0-9-]{1,62}$",
            "title": "Resource",
            "type": "string"
          },
          "collection": {
            "title": "Collection",
            "type": "string"
          },
          "top_k": {
            "default": 4,
            "maximum": 100,
            "minimum": 1,
            "title": "Top K",
            "type": "integer"
          },
          "filter": {
            "anyOf": [
              {
                "additionalProperties": {
                  "$ref": "#/$defs/JsonValue"
                },
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Filter"
          },
          "min_score": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Similarity score threshold. Hits below it are dropped, so a filled collection can still yield zero documents — which is what makes an empty-result router branch fire. Score semantics follow the collection's distance metric (cosine: 1.0 = identical).",
            "title": "Min Score"
          }
        },
        "required": [
          "resource",
          "collection"
        ],
        "title": "RetrievalNodeConfig",
        "type": "object"
      },
      "inputs": [
        {
          "name": "query",
          "type": "text",
          "label": "Query"
        }
      ],
      "outputs": [
        {
          "name": "documents",
          "type": "documents",
          "label": "Documents"
        }
      ],
      "dynamic_inputs": null,
      "dynamic_outputs": null,
      "ui": {
        "resource": {
          "widget": "resource",
          "label": "Vector DB",
          "help": "",
          "placeholder": "",
          "resource_kind": "vector_db",
          "advanced": false,
          "toggleable": false
        },
        "collection": {
          "widget": "text",
          "label": "Collection",
          "help": "",
          "placeholder": "",
          "resource_kind": null,
          "advanced": false,
          "toggleable": false
        },
        "top_k": {
          "widget": "number",
          "label": "Top K",
          "help": "",
          "placeholder": "",
          "resource_kind": null,
          "advanced": false,
          "toggleable": false
        },
        "min_score": {
          "widget": "number",
          "label": "Min Score",
          "help": "Similarity threshold — hits below it are dropped, so an empty-result router branch can actually fire (cosine: 1.0 = identical).",
          "placeholder": "",
          "resource_kind": null,
          "advanced": true,
          "toggleable": false
        },
        "filter": {
          "widget": "json",
          "label": "Filter",
          "help": "",
          "placeholder": "",
          "resource_kind": null,
          "advanced": true,
          "toggleable": false
        }
      },
      "default_config": {
        "top_k": 4
      }
    },
    {
      "type": "rerank",
      "version": 1,
      "label": "Rerank",
      "icon": "arrow-down-up",
      "category": "rag",
      "description": "Rerank retrieved documents by relevance to the query; keep the best top_n.",
      "config_schema": {
        "additionalProperties": false,
        "description": "Reorder retrieved documents by relevance to the query (v1.1).\n\nThe retrieval node returns a similarity top-k; a reranker (cross-encoder)\nthen scores each document against the query directly and keeps the best\n``top_n`` — the standard quality step between retrieval and the LLM. Reuses\na ``model_provider`` resource whose ``base_url`` serves a ``/rerank``\nendpoint (Cohere/Jina/TEI-style); no new resource kind.",
        "properties": {
          "resource": {
            "pattern": "^[a-z0-9][a-z0-9-]{1,62}$",
            "title": "Resource",
            "type": "string"
          },
          "model": {
            "default": "",
            "title": "Model",
            "type": "string"
          },
          "top_n": {
            "default": 4,
            "maximum": 100,
            "minimum": 1,
            "title": "Top N",
            "type": "integer"
          },
          "min_score": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Rerank score threshold; documents scoring below it are dropped, so a reranked set can be empty (which lets an empty-result router branch fire). Score scale is the reranker's own relevance score, not the retrieval metric.",
            "title": "Min Score"
          }
        },
        "required": [
          "resource"
        ],
        "title": "RerankNodeConfig",
        "type": "object"
      },
      "inputs": [
        {
          "name": "query",
          "type": "text",
          "label": "Query"
        },
        {
          "name": "documents",
          "type": "documents",
          "label": "Documents"
        }
      ],
